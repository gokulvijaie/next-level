# Drupal backend base URL (no trailing slash).
NEXT_PUBLIC_DRUPAL_BASE_URL=http://localhost:8888

# Product bundle + category vocabulary machine names in Drupal Commerce.
DRUPAL_PRODUCT_BUNDLE=default
DRUPAL_CATEGORY_VOCABULARY=product_category

# Shared secret for on-demand revalidation. Must match the value in
# Drupal's settings.php: $settings['smartgrids_revalidate_secret'].
REVALIDATE_SECRET=change-me

# Public URL of this storefront (canonical URLs, sitemap, OG tags).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cart mode: "drupal" uses the Commerce cart REST endpoints (requires the
# commerce_cart_api contrib module + CORS with credentials). "local" keeps
# a client-side cart (checkout handoff to Drupal at /cart).
NEXT_PUBLIC_CART_MODE=local

# Shared secret for the checkout endpoint. Must match Drupal settings.php
# ($settings["smartgrids_checkout_secret"]).
CHECKOUT_SECRET=change-me
