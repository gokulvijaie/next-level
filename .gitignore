# Node dependencies and frontend build caches.
node_modules/
.npm/
.yarn/

# Environment and editor-local files.
.env
.env.*
!.env.example
.DS_Store
Thumbs.db

# Logs and caches.
*.log
/.cache/
/.phpunit.result.cache
