# Drupal / Composer dependencies generated by composer install.
/vendor/
/web/core/
/web/libraries/
/web/modules/contrib/
/web/profiles/contrib/
/web/themes/contrib/
/drush/Commands/contrib/

# Drupal runtime data and machine-local site configuration.
/web/sites/*/files/
/web/sites/*/private/
/web/sites/*/translations/
/web/sites/*/settings.php
/web/sites/*/settings.local.php
/web/sites/*/services.local.yml

# Next.js / Node dependencies and generated output.
node_modules/
.next/
.next-build/
out/
dist/
.turbo/
.vercel/
.npm/
.yarn/
.pnpm-store/
*.tsbuildinfo
next-env.d.ts

# Test reports and coverage output.
coverage/
playwright-report/
test-results/
.phpunit.result.cache

# Environment files may contain Drupal, database, or API credentials.
.env
.env.*
!.env.example
!**/.env.example

# Logs, caches, editor state, and operating-system metadata.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
