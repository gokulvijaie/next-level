{#
/**
 * @file
 * Custom user profile card.
 *
 * Available variables:
 * - content: Rendered user fields such as content.user_picture.
 * - attributes: HTML attributes for the container element.
 * - user: A Drupal User entity.
 */
#}
{% set full_name = user.getDisplayName() %}
{% set first_name = '' %}
{% set last_name = '' %}
{% set age = '' %}
{% set date_of_birth = '' %}
{% if user.hasField('field_first_name') and not user.get('field_first_name').isEmpty() %}
  {% set first_name = user.get('field_first_name').value %}
{% endif %}
{% if user.hasField('field_last_name') and not user.get('field_last_name').isEmpty() %}
  {% set last_name = user.get('field_last_name').value %}
{% endif %}
{% if first_name or last_name %}
  {% set full_name = (first_name ~ ' ' ~ last_name)|trim %}
{% elseif user.hasField('field_full_name') and not user.get('field_full_name').isEmpty() %}
  {% set full_name = user.get('field_full_name').value %}
{% endif %}
{% if user.hasField('field_date_of_birth') and not user.get('field_date_of_birth').isEmpty() %}
  {% set date_of_birth = user.get('field_date_of_birth').value %}
  {% set age = 'now'|date('Y') - date_of_birth|date('Y') %}
  {% if 'now'|date('md') < date_of_birth|date('md') %}
    {% set age = age - 1 %}
  {% endif %}
  {% if age < 0 %}
    {% set age = '' %}
  {% endif %}
{% endif %}

{% set username = user.getAccountName() %}
{% set email = user.getEmail() %}
{% set initials_source = (first_name ? first_name|slice(0, 1) : username|slice(0, 1)) ~ (last_name ? last_name|slice(0, 1) : username|slice(1, 1)) %}
{% set initials = initials_source|upper %}
{% set profile_picture_uri = '' %}
{% if user.hasField('user_picture') and not user.get('user_picture').isEmpty() and user.get('user_picture').entity %}
  {% set profile_picture_uri = user.get('user_picture').entity.uri.value %}
{% endif %}

<article{{ attributes.addClass('smartgrids-user-profile') }}>
  <div class="smartgrids-user-profile__panel">
    <div class="smartgrids-user-profile__banner" aria-hidden="true"></div>

    <div class="smartgrids-user-profile__body">
      <div class="smartgrids-user-profile__media">
        {% if profile_picture_uri %}
          <div class="smartgrids-user-profile__picture">
            <img src="{{ file_url(profile_picture_uri) }}" alt="{{ full_name }} profile picture" loading="lazy">
          </div>
        {% else %}
          <div class="smartgrids-user-profile__picture smartgrids-user-profile__picture--fallback" aria-hidden="true">
            {{ initials }}
          </div>
        {% endif %}
      </div>

      <div class="smartgrids-user-profile__details">
        <p class="smartgrids-user-profile__eyebrow">User profile</p>
        <h1 class="smartgrids-user-profile__name">{{ full_name }}</h1>
        <p class="smartgrids-user-profile__username">@{{ username }}</p>

        <div class="smartgrids-user-profile__summary" aria-label="Profile details">
          <dl class="smartgrids-user-profile__meta">
            <div class="smartgrids-user-profile__meta-item smartgrids-user-profile__meta-item--name">
              <dt>Full name</dt>
              <dd>{{ full_name }}</dd>
            </div>
            <div class="smartgrids-user-profile__meta-item smartgrids-user-profile__meta-item--email">
              <dt>Email</dt>
              <dd>
                {% if email %}
                  <a href="mailto:{{ email }}">{{ email }}</a>
                {% else %}
                  <span>Not provided</span>
                {% endif %}
              </dd>
            </div>
            <div class="smartgrids-user-profile__meta-item smartgrids-user-profile__meta-item--username">
              <dt>Username</dt>
              <dd>{{ username }}</dd>
            </div>
            {% if age %}
              <div class="smartgrids-user-profile__meta-item smartgrids-user-profile__meta-item--age">
                <dt>Age</dt>
                <dd>{{ age }}</dd>
              </div>
            {% endif %}
          </dl>
        </div>
      </div>
    </div>
  </div>

</article>
